theme_override_font_sizes/normal_font_size = 24
bbcode_enabled = true
text = "[center]



At the bottom left you see your toolbar. Click any of 
these icons to open the respective app. When the app 
is open, you'll see a dot underneath. To close the app 
simply click the icon when the window is open.

The apps:"
fit_content = true
scroll_active = false

[node name="RecycleButton" type="Sprite2D" parent="Work Guide/Panel/ScrollContainer/VBoxContainer" unique_id=1148236798]
position = Vector2(220, 887.9995)
scale = Vector2(0.101690315, 0.10169031)
texture = ExtResource("4_qrswn")

[node name="RichTextLabel5" type="RichTextLabel" parent="Work Guide/Panel/ScrollContainer/VBoxContainer" unique_id=1412381876]
layout_mode = 2
theme_override_colors/default_color = Color(0.23119366, 0.3662076, 0.5810717, 1)
theme_override_font_sizes/normal_font_size = 24
bbcode_enabled = true
text = "			Waste Planner:
			This is what you will use to talk to clients
			and thereby earn you pay!
			Open this and you should quickly see that 
			a client has started a conversation in the 
			green area to the left.

			The Fridge:
			Here the ingredients that your client has
			in their fridge, will be displayed. As they use
			ingredients for your meal recommendation,
			you'll see the ingredients disappear.

			Client Satisfaction:
			Here you will see how satisfied the client is
			with your consultation. Max satisfaction is
			dependent on the number of items in the 
			fridge.

			Webcam:
			Here you will be able to see the client you're
			talking to. Remember, they can see you too, 
			so smile!"
fit_content = true
scroll_active = false
tab_size = 18

